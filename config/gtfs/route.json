{
  "exclude_routes": [
    {
      "route_id": "5",
      "route_short_name": "5",
      "route_comment": "Light-rail != Streetcars (shown w/ subway on official web site)"
    },
    {
      "route_id": "6",
      "route_short_name": "6",
      "route_comment": "Light-rail != Streetcars (shown w/ subway on official web site)"
    }
  ],
  "default_route_id_enabled": true,
  "use_route_short_name_for_route_id": true,
  "default_route_long_name_enabled": true,
  "stop_headsign_remove_route_long_name_complex": true,
  "stop_headsign_remove_route_long_name_cleaner": {
    "regex": "((\\d+(/\\d+)?)([a-z] )?(\\s*(%1$s)\\s*)?)",
    "ignore_case": true,
    "replacement": "$4"
  },
  "route_colors_ignored": [
  ],
  "direction_types": [
    1,
    0
  ],
  "direction_types_comment": "string(0) for route 5 (& 6) only",
  "direction_finder_enabled": true,
  "direction_headsign_cleaners": [
    {
      "regex": "((?<=[A-Z]{4,5}) - .*$)",
      "ignore_case": true
    }
  ],
  "trip_excludes": [
    {
      "trip_headsign_regex": "(not in service)",
      "ignore_case": true
    }
  ],
  "trip_headsign_cleaners": [
    {
      "regex": "(^(([a-z]+) - )?(\\d+(/\\d+)?)?([a-z] )?((.*)\\s*(towards|to))? (.*))",
      "ignore_case": true,
      "replacement": "$6$10"
    },
    {
      "regex": "(( -)? extra fare required .*$)",
      "ignore_case": true
    },
    {
      "regex": "replacement bus",
      "ignore_case": true,
      "is_word": true
    },
    {
      "regex": "short turn",
      "ignore_case": true,
      "is_word": true
    },
    {
      "regex": "blue night",
      "ignore_case": true,
      "is_word": true
    }
  ],
  "stop_time_excludes": [
    {
      "stop_time_headsign_regex": "(Not In Service)",
      "ignore_case": true
    }
  ],
  "stop_name_cleaners": [
    {
      "regex": "( towards .*$)",
      "ignore_case": true
    },
    {
      "regex": "side",
      "ignore_case": true,
      "is_word": true
    }
  ]
}
